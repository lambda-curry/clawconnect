{
  "name": "@clawconnect/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CLI for connecting AI coding agents to OpenClaw instances",
  "author": "Jake Ruesink",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lambda-curry/clawconnect.git",
    "directory": "packages/cli"
  },
  "bin": {
    "clawconnect": "./dist/bin.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./bin": "./dist/bin.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch"
  },
  "dependencies": {
    "@clawconnect/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "inlinedDependencies": {
    "ws": "8.20.0"
  }
}
